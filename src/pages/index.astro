---
import BaseLayout from '../layouts/BaseLayout.astro';
import Table from '../components/Table.astro';
import StrollerCard from '../components/StrollerCard.astro';
import AuthorBox from '../components/AuthorBox.astro';
import strollersData from '../data/strollers.json';
---

<BaseLayout title="Maxi-Cosi vs Safety 1st: Qual Carrinho de Bebê Premium Vale a Pena em 2026?">
  <main class="max-w-5xl mx-auto px-5 sm:px-8">
    
    <!-- ═══════════════════════════════════════ -->
    <!-- HERO — Emocional, editorial, premium    -->
    <!-- ═══════════════════════════════════════ -->
    <header class="text-center py-16 md:py-24 space-y-8 max-w-3xl mx-auto">
      
      <!-- Tag editorial -->
      <div class="inline-flex items-center gap-2 bg-gold-50 text-warm-700 border border-gold-200/60 text-[10px] font-bold px-5 py-2 rounded-full uppercase tracking-[0.2em]">
        <svg class="w-3.5 h-3.5 text-gold-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z" clip-rule="evenodd"/></svg>
        Guia do Enxoval Seguro — 2026
      </div>
      
      <!-- Título -->
      <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl text-warm-900 leading-[1.1] text-balance">
        Qual Carrinho Premium <br class="hidden sm:inline"/>
        <span class="italic text-warm-600">Realmente</span> Vale o Investimento?
      </h1>
      
      <!-- Subtítulo -->
      <p class="text-warm-500 text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto font-light">
        Não compre um carrinho de bebê caro sem ler isto antes. Analisamos os 
        <strong class="text-warm-700 font-medium">3 maiores sistemas de viagem premium</strong> 
        da Amazon Brasil — baseados em segurança real, amortecimento e praticidade.
      </p>
      
      <!-- Indicadores de confiança -->
      <div class="flex flex-wrap justify-center gap-6 text-xs text-warm-400 pt-2">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-sage-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Atualizado em Maio 2026
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-sage-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          3 Modelos Analisados
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-sage-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          100% Independente
        </span>
      </div>

      <!-- Seta decorativa -->
      <div class="pt-4 animate-float">
        <svg class="w-5 h-5 mx-auto text-warm-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
      </div>
    </header>

    <!-- ═══════════════════════════════════════ -->
    <!-- CAIXA DE AUTORA                         -->
    <!-- ═══════════════════════════════════════ -->
    <section class="mb-20">
      <AuthorBox />
    </section>

    <!-- ═══════════════════════════════════════ -->
    <!-- A ARMADILHA DO BARATO                   -->
    <!-- ═══════════════════════════════════════ -->
    <section class="mb-20 scroll-reveal">
      <div class="text-center mb-10 space-y-3">
        <div class="section-divider"></div>
        <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl text-warm-900 mt-6">
          A Armadilha do "Barato que Sai Caro"
        </h2>
        <p class="text-warm-500 text-base sm:text-lg max-w-2xl mx-auto">
          Ver carrinhos de R$ 1.500 a R$ 3.500 assusta. Mas não cometa o erro que milhares de pais cometem.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6">
        <!-- Carrinhos baratos -->
        <div class="relative bg-white rounded-3xl p-7 sm:p-8 border border-blush-100/60 shadow-soft overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blush-300 to-blush-400"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-2xl bg-blush-50 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-blush-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.5 0L4.268 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            </div>
            <h3 class="font-serif text-lg text-warm-900">Carrinhos Ultra-Baratos<br/><span class="text-sm text-warm-400 font-sans font-normal">R$ 400 — R$ 700</span></h3>
          </div>
          <ul class="space-y-4 text-sm text-warm-600">
            <li class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-blush-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-blush-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              </span>
              <span><strong class="text-warm-800">Rodas de plástico sem suspensão:</strong> Trepidam violentamente em calçadas, acordando o bebê a cada rachadura.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-blush-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-blush-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              </span>
              <span><strong class="text-warm-800">Estruturas que folgam:</strong> Após 3 meses de uso, parecem que o carrinho vai desmontar com o bebê dentro.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-blush-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-blush-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              </span>
              <span><strong class="text-warm-800">Tecidos sintéticos baratos:</strong> Acumulam calor excessivo, causando irritações na pele delicada do bebê.</span>
            </li>
          </ul>
        </div>

        <!-- Carrinhos premium -->
        <div class="relative bg-white rounded-3xl p-7 sm:p-8 border border-sage-100/60 shadow-soft overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-sage-300 to-sage-400"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-2xl bg-sage-50 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h3 class="font-serif text-lg text-warm-900">Carrinhos Premium Analisados<br/><span class="text-sm text-warm-400 font-sans font-normal">Investimento inteligente</span></h3>
          </div>
          <ul class="space-y-4 text-sm text-warm-600">
            <li class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-sage-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </span>
              <span><strong class="text-warm-800">Amortecimento real nas 4 rodas:</strong> Suspensão de alto desempenho que protege o pescoço e a coluna do recém-nascido.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-sage-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </span>
              <span><strong class="text-warm-800">Chassis de alumínio premium:</strong> Extrema leveza para erguer com robustez que suporta até 22kg por anos.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-sage-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </span>
              <span><strong class="text-warm-800">Fechamento com uma mão:</strong> Mecanismo de mola que fecha o carrinho sozinho enquanto você segura o bebê.</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Dica de revenda -->
      <div class="mt-6 bg-gradient-to-br from-gold-50 to-cream-100 rounded-3xl p-6 sm:p-7 border border-gold-200/50 shadow-soft">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-2xl bg-gold-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="space-y-1">
            <h4 class="font-bold text-warm-800 text-sm">O Segredo do Valor de Revenda</h4>
            <p class="text-warm-600 text-sm leading-relaxed">
              Carrinhos Maxi-Cosi são extremamente desejados no mercado de usados. Invista R$ 3.000 hoje, use com cuidado por 3 anos e revenda por R$ 1.500 a R$ 1.800. <strong class="text-warm-800">Custo real: menos de R$ 40/mês</strong> por um conforto insuperável.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ -->
    <!-- RESUMO RÁPIDO — Cards comparativos      -->
    <!-- ═══════════════════════════════════════ -->
    <section class="mb-24">
      <div class="text-center mb-10 space-y-3">
        <div class="section-divider"></div>
        <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl text-warm-900 mt-6">
          Nossas 3 Recomendações
        </h2>
        <p class="text-warm-500 text-base sm:text-lg max-w-xl mx-auto">
          Para quem tem pressa — veja a melhor opção direto na Amazon Brasil.
        </p>
      </div>
      <Table strollers={strollersData} />
    </section>

    <!-- ═══════════════════════════════════════ -->
    <!-- ANÁLISES DETALHADAS                     -->
    <!-- ═══════════════════════════════════════ -->
    <section class="mb-24">
      <div class="text-center mb-12 space-y-3">
        <div class="section-divider"></div>
        <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl text-warm-900 mt-6">
          Análise Detalhada de Cada Modelo
        </h2>
        <p class="text-warm-500 text-base sm:text-lg max-w-2xl mx-auto">
          Analisamos manuais, testes de impacto e centenas de avaliações de compradores reais para compilar os prós e contras sinceros.
        </p>
      </div>

      <div class="space-y-10">
        {strollersData.map((stroller, i) => (
          <StrollerCard stroller={stroller} index={i} />
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════ -->
    <!-- GUIA DE ESCOLHA                         -->
    <!-- ═══════════════════════════════════════ -->
    <section class="mb-24 scroll-reveal">
      <div class="bg-white rounded-3xl shadow-card border border-warm-100/40 overflow-hidden">
        
        <!-- Header da seção -->
        <div class="bg-gradient-to-br from-cream-100 via-white to-gold-50/20 px-8 sm:px-10 py-8 border-b border-warm-100/30">
          <h2 class="font-serif text-2xl sm:text-3xl text-warm-900">
            Qual Deles Se Adapta à Sua Família?
          </h2>
          <p class="text-warm-500 text-sm sm:text-base mt-2">
            Reflita sobre estas 3 perguntas simples antes de decidir.
          </p>
        </div>
        
        <div class="px-8 sm:px-10 py-8 space-y-8">
          <!-- Pergunta 1 -->
          <div class="flex gap-5">
            <div class="flex-shrink-0">
              <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-gold-100 to-cream-200 flex items-center justify-center shadow-sm border border-gold-200/50">
                <span class="text-warm-700 font-bold text-sm">1</span>
              </div>
            </div>
            <div class="space-y-2">
              <h3 class="font-bold text-warm-900 text-base">Você viaja muito de avião ou tem porta-malas compacto?</h3>
              <p class="text-warm-500 text-sm leading-relaxed">
                O <strong class="text-warm-700">Maxi-Cosi Eva³</strong> é insuperável. Dobra automaticamente com tamanho de mala de bordo e vai direto na cabine de aeronaves Latam, Azul ou Gol sem precisar despachar.
              </p>
            </div>
          </div>

          <div class="border-t border-warm-100/40"></div>

          <!-- Pergunta 2 -->
          <div class="flex gap-5">
            <div class="flex-shrink-0">
              <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-gold-100 to-cream-200 flex items-center justify-center shadow-sm border border-gold-200/50">
                <span class="text-warm-700 font-bold text-sm">2</span>
              </div>
            </div>
            <div class="space-y-2">
              <h3 class="font-bold text-warm-900 text-base">Sua prioridade é amortecimento para calçadas do dia a dia?</h3>
              <p class="text-warm-500 text-sm leading-relaxed">
                O <strong class="text-warm-700">Safety 1st Spark Plus Trio</strong> possui suspensão real nas 4 rodas e rodas de borracha mais largas que rolam suavemente sobre pisos irregulares brasileiros.
              </p>
            </div>
          </div>

          <div class="border-t border-warm-100/40"></div>

          <!-- Pergunta 3 -->
          <div class="flex gap-5">
            <div class="flex-shrink-0">
              <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-gold-100 to-cream-200 flex items-center justify-center shadow-sm border border-gold-200/50">
                <span class="text-warm-700 font-bold text-sm">3</span>
              </div>
            </div>
            <div class="space-y-2">
              <h3 class="font-bold text-warm-900 text-base">Quer o conjunto completo com a melhor engenharia de segurança?</h3>
              <p class="text-warm-500 text-sm leading-relaxed">
                O <strong class="text-warm-700">Travel System Maxi-Cosi Eva³ Trio</strong> é o mais luxuoso e seguro do mercado nacional. O bebê conforto Citi² possui espuma de memória inteligente contra impactos, com certificações de segurança que superam as exigências nacionais.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ -->
    <!-- DICA FINAL — CTA emocional              -->
    <!-- ═══════════════════════════════════════ -->
    <section class="mb-16 scroll-reveal">
      <div class="relative bg-gradient-to-br from-warm-900 via-warm-800 to-warm-900 rounded-3xl p-8 sm:p-10 md:p-12 overflow-hidden text-center">
        
        <!-- Detalhes decorativos -->
        <div class="absolute top-0 left-0 w-32 h-32 bg-gold-400/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute bottom-0 right-0 w-48 h-48 bg-gold-400/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
        
        <div class="relative space-y-5 max-w-2xl mx-auto">
          <div class="inline-flex items-center gap-2 bg-gold-400/10 text-gold-300 text-[10px] font-bold px-4 py-1.5 rounded-full uppercase tracking-[0.15em] border border-gold-400/20">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Dica de Mãe
          </div>
          
          <h3 class="font-serif text-2xl sm:text-3xl text-cream-100 leading-snug">
            Garanta o Preço do Dia Antes que Mude
          </h3>
          
          <p class="text-warm-300 text-sm sm:text-base leading-relaxed">
            Preços e estoques dos carrinhos na Amazon Brasil mudam diariamente. Se você gostou de algum modelo, 
            <strong class="text-cream-100">adicione ao carrinho agora</strong> — mesmo se for fechar depois. 
            Isso trava o preço promocional e nos ajuda a manter este guia independente no ar.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-3 justify-center pt-3">
            {strollersData.map((stroller) => (
              <a 
                href={stroller.affiliateLink}
                target="_blank"
                rel="noopener noreferrer"
                data-affiliate-btn
                data-product-name={stroller.name}
                class="btn-primary text-xs sm:text-sm py-3 px-6"
              >
                {stroller.badgeIcon} Ver {stroller.name.split(' ').slice(-1)[0]}
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
