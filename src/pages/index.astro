---
import BaseLayout from '../layouts/BaseLayout.astro';
import Table from '../components/Table.astro';
import StrollerCard from '../components/StrollerCard.astro';
import AuthorBox from '../components/AuthorBox.astro';
import strollersData from '../data/strollers.json';
---

<BaseLayout title="Seu Bebê Merece o Melhor Carrinho — Guia 2026 | BebêSeguro">
  <main>
    
    <!-- ═══════════════════════════════════════════════════ -->
    <!-- HERO — Impacto emocional em 3 segundos              -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="relative overflow-hidden">
      
      {/* Fundo com gradiente vivo */}
      <div class="absolute inset-0 bg-gradient-to-b from-baby-pink-soft via-baby-peach/30 to-transparent"></div>
      
      {/* Bolhas decorativas animadas */}
      <div class="absolute top-10 left-[10%] w-60 h-60 rounded-full bg-baby-pink/40 blur-3xl animate-float"></div>
      <div class="absolute top-20 right-[8%] w-48 h-48 rounded-full bg-baby-lavender/30 blur-3xl animate-float-delayed"></div>
      <div class="absolute bottom-10 left-[30%] w-40 h-40 rounded-full bg-baby-mint/30 blur-3xl animate-float-slow"></div>
      <div class="absolute top-1/2 right-[25%] w-32 h-32 rounded-full bg-baby-yellow/25 blur-3xl animate-float"></div>
      
      {/* Elementos decorativos flutuantes */}
      <div class="absolute top-[15%] right-[12%] text-4xl animate-float opacity-40 hidden lg:block">🧸</div>
      <div class="absolute top-[25%] left-[8%] text-3xl animate-float-delayed opacity-30 hidden lg:block">⭐</div>
      <div class="absolute bottom-[20%] right-[18%] text-3xl animate-float-slow opacity-35 hidden lg:block">🌙</div>
      <div class="absolute bottom-[30%] left-[15%] text-2xl animate-wiggle opacity-30 hidden lg:block">💛</div>

      <div class="relative max-w-5xl mx-auto px-5 sm:px-8 pt-16 sm:pt-20 md:pt-28 pb-20 md:pb-32">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
          
          {/* Texto do hero */}
          <div class="text-center lg:text-left space-y-7 max-w-xl mx-auto lg:mx-0">
            
            {/* Tag */}
            <div class="inline-flex items-center gap-2 bg-white/70 backdrop-blur-sm text-brand-600 text-[11px] font-bold px-4 py-2 rounded-full border border-brand-100/40 animate-fade-up">
              <span class="w-2 h-2 rounded-full bg-brand-400 animate-pulse"></span>
              Guia do Enxoval 2026
            </div>
            
            {/* Título — O HOOK */}
            <h1 class="font-display text-4xl sm:text-5xl md:text-6xl text-text-primary leading-[1.08]">
              Seu bebê merece <br/>
              <span class="relative inline-block">
                <span class="relative z-10 text-brand-500">o melhor passeio</span>
                <svg class="absolute -bottom-1 left-0 w-full h-3 text-baby-pink-deep/40" viewBox="0 0 200 12" fill="currentColor" preserveAspectRatio="none"><path d="M0 8c30-6 60 2 100 0s70 4 100-2v6H0z"/></svg>
              </span>
              <br/>da vida dele. 🤍
            </h1>
            
            {/* Subtítulo emocional */}
            <p class="text-text-secondary text-lg sm:text-xl leading-relaxed">
              A gente analisou <strong class="text-text-primary">cada detalhe</strong> dos carrinhos mais seguros da Amazon pra você não perder tempo — e não errar.
            </p>
            
            {/* CTAs */}
            <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
              <a href="#recomendacoes" class="btn-cta text-base px-10 py-4">
                Ver os 3 melhores
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
              </a>
              <a href="#analises" class="btn-soft text-sm">
                Ler análises completas
              </a>
            </div>

            {/* Social proof rápido */}
            <div class="flex flex-wrap justify-center lg:justify-start gap-4 text-[11px] text-text-light pt-2">
              <span class="flex items-center gap-1.5">
                <span class="text-brand-400">♥</span> 2.400+ mães já leram
              </span>
              <span class="flex items-center gap-1.5">
                <span class="text-baby-yellow-deep">★★★★★</span> 4.9/5
              </span>
            </div>
          </div>
          
          {/* Visual do hero — Área para imagem */}
          <div class="relative flex justify-center lg:justify-end">
            <div class="relative">
              {/* Forma de fundo */}
              <div class="absolute inset-0 scale-110 bg-gradient-to-br from-baby-pink/30 to-baby-lavender/30 rounded-[3rem] rotate-3 blur-sm"></div>
              
              {/* Card principal de imagem */}
              <div class="relative w-72 h-80 sm:w-80 sm:h-96 rounded-[2.5rem] bg-gradient-to-br from-baby-pink/60 via-baby-lavender/40 to-baby-mint/40 border-2 border-white/60 shadow-image overflow-hidden">
                <img 
                  src="/img/hero-bebe.webp" 
                  alt="Bebê feliz e seguro no carrinho"
                  class="w-full h-full object-cover"
                />
              </div>
              
              {/* Cards flutuantes decorativos */}
              <div class="absolute -top-4 -right-4 bg-white rounded-2xl shadow-card p-3 animate-float border border-brand-100/20">
                <div class="flex items-center gap-2">
                  <span class="text-xl">🛡️</span>
                  <div>
                    <p class="text-[10px] font-bold text-text-primary">Segurança</p>
                    <p class="text-[9px] text-text-light">Máxima</p>
                  </div>
                </div>
              </div>
              
              <div class="absolute -bottom-3 -left-5 bg-white rounded-2xl shadow-card p-3 animate-float-delayed border border-brand-100/20">
                <div class="flex items-center gap-2">
                  <span class="text-xl">✨</span>
                  <div>
                    <p class="text-[10px] font-bold text-text-primary">5 Anos</p>
                    <p class="text-[9px] text-text-light">de Garantia</p>
                  </div>
                </div>
              </div>
              
              <div class="absolute top-1/2 -right-6 bg-white rounded-2xl shadow-card p-3 animate-float-slow border border-brand-100/20">
                <div class="flex items-center gap-2">
                  <span class="text-xl">🪶</span>
                  <div>
                    <p class="text-[10px] font-bold text-text-primary">Ultra Leve</p>
                    <p class="text-[9px] text-text-light">7,8 kg</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Onda inferior */}
      <div class="absolute bottom-0 left-0 right-0">
        <svg viewBox="0 0 1440 60" fill="none" class="w-full" preserveAspectRatio="none"><path d="M0 60V30C240 0 480 50 720 25C960 0 1200 40 1440 20V60H0Z" fill="white"/></svg>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CONFIANÇA RÁPIDA — Ícones visuais                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="max-w-5xl mx-auto px-5 sm:px-8 -mt-4 mb-16 relative z-10">
      <div class="reveal grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="card text-center p-5 space-y-2">
          <span class="text-3xl block">🔬</span>
          <p class="font-bold text-text-primary text-xs">Analisados em Detalhe</p>
          <p class="text-text-muted text-[10px]">Manuais, testes e reviews</p>
        </div>
        <div class="card text-center p-5 space-y-2">
          <span class="text-3xl block">💰</span>
          <p class="font-bold text-text-primary text-xs">Sem Custo Extra</p>
          <p class="text-text-muted text-[10px]">Mesmo preço da Amazon</p>
        </div>
        <div class="card text-center p-5 space-y-2">
          <span class="text-3xl block">🇧🇷</span>
          <p class="font-bold text-text-primary text-xs">Entrega Nacional</p>
          <p class="text-text-muted text-[10px]">Amazon Brasil com Prime</p>
        </div>
        <div class="card text-center p-5 space-y-2">
          <span class="text-3xl block">❤️</span>
          <p class="font-bold text-text-primary text-xs">Feito por Mães</p>
          <p class="text-text-muted text-[10px]">Guia 100% independente</p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- AUTORA                                              -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="max-w-3xl mx-auto px-5 sm:px-8 mb-20">
      <AuthorBox />
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- POR QUE NÃO COMPRAR BARATO — Visual impactante      -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="max-w-5xl mx-auto px-5 sm:px-8 mb-24">
      <div class="text-center mb-12 space-y-4 reveal">
        <span class="text-4xl block">🚫</span>
        <h2 class="font-display text-3xl sm:text-4xl text-text-primary">
          Antes de comprar um carrinho baratinho...
        </h2>
        <p class="text-text-secondary text-base sm:text-lg max-w-2xl mx-auto">
          A gente sabe que dá um aperto no coração ver os preços. Mas olha o que acontece com quem economiza no lugar errado:
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        {/* Barato */}
        <div class="reveal reveal-delay-1">
          <div class="relative card overflow-hidden">
            <div class="h-2 bg-gradient-to-r from-red-300 to-red-400"></div>
            <div class="p-7 space-y-5">
              <div class="flex items-center gap-3">
                <span class="text-3xl">😰</span>
                <div>
                  <h3 class="font-display text-lg text-text-primary">Carrinho de R$ 500</h3>
                  <p class="text-red-400 text-xs font-medium">O que parece economia...</p>
                </div>
              </div>
              <ul class="space-y-4">
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <span class="w-6 h-6 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0 mt-0.5 text-red-400 text-xs">✗</span>
                  <span><strong class="text-text-primary">Treme em toda calçada</strong> — rodas de plástico duro sem amortecimento. O bebê acorda com cada buraco.</span>
                </li>
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <span class="w-6 h-6 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0 mt-0.5 text-red-400 text-xs">✗</span>
                  <span><strong class="text-text-primary">Folga em 3 meses</strong> — a estrutura de plástico começa a ranger e balançar com uso diário.</span>
                </li>
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <span class="w-6 h-6 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0 mt-0.5 text-red-400 text-xs">✗</span>
                  <span><strong class="text-text-primary">Tecido que sufoca</strong> — material sintético que acumula calor e irrita a pele do bebê.</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        {/* Premium */}
        <div class="reveal reveal-delay-2">
          <div class="relative card overflow-hidden">
            <div class="h-2 bg-gradient-to-r from-baby-mint-deep to-emerald-400"></div>
            <div class="p-7 space-y-5">
              <div class="flex items-center gap-3">
                <span class="text-3xl">🥰</span>
                <div>
                  <h3 class="font-display text-lg text-text-primary">Os que a gente recomenda</h3>
                  <p class="text-baby-mint-deep text-xs font-medium">Investimento inteligente</p>
                </div>
              </div>
              <ul class="space-y-4">
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <span class="w-6 h-6 rounded-full bg-baby-mint flex items-center justify-center flex-shrink-0 mt-0.5 text-baby-mint-deep text-xs">✓</span>
                  <span><strong class="text-text-primary">Suspensão real nas 4 rodas</strong> — protege o pescoço e a coluna do recém-nascido em qualquer piso.</span>
                </li>
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <span class="w-6 h-6 rounded-full bg-baby-mint flex items-center justify-center flex-shrink-0 mt-0.5 text-baby-mint-deep text-xs">✓</span>
                  <span><strong class="text-text-primary">Alumínio premium</strong> — ultra leve para carregar, mas forte para durar anos de uso diário.</span>
                </li>
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <span class="w-6 h-6 rounded-full bg-baby-mint flex items-center justify-center flex-shrink-0 mt-0.5 text-baby-mint-deep text-xs">✓</span>
                  <span><strong class="text-text-primary">Fecha com uma mão só</strong> — enquanto você segura o bebê no colo, o carrinho fecha sozinho.</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      {/* Dica de revenda */}
      <div class="reveal mt-6">
        <div class="card bg-gradient-to-r from-baby-yellow/40 to-baby-peach/30 p-6 sm:p-7 border-baby-yellow-deep/20">
          <div class="flex items-start gap-4">
            <span class="text-3xl flex-shrink-0">💡</span>
            <div>
              <h4 class="font-bold text-text-primary text-sm mb-1">Segredo: carrinho premium é investimento</h4>
              <p class="text-text-secondary text-sm leading-relaxed">
                Maxi-Cosi e Safety 1st são disputados no mercado de usados. Invista R$ 3.000, use 3 anos e revenda por R$ 1.800. <strong class="text-text-primary">Custo real: R$ 33/mês.</strong> Menos que uma fralda por dia.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- NOSSAS 3 RECOMENDAÇÕES — Vitrine visual              -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section id="recomendacoes" class="scroll-mt-20 mb-28">
      {/* Fundo decorativo */}
      <div class="relative bg-gradient-to-b from-baby-pink-soft/50 via-white to-white py-16 sm:py-20">
        <div class="absolute top-0 left-0 right-0">
          <svg viewBox="0 0 1440 40" fill="none" class="w-full" preserveAspectRatio="none"><path d="M0 0v20C240 40 480 10 720 30C960 50 1200 10 1440 30V0H0Z" fill="white"/></svg>
        </div>
        
        <div class="max-w-5xl mx-auto px-5 sm:px-8">
          <div class="text-center mb-12 space-y-4 reveal">
            <span class="text-4xl block">🏆</span>
            <h2 class="font-display text-3xl sm:text-4xl text-text-primary">
              Os 3 carrinhos que a gente escolheu
            </h2>
            <p class="text-text-secondary text-base sm:text-lg max-w-xl mx-auto">
              Depois de testar, pesquisar e comparar — esses são os que a gente recomenda de olhos fechados.
            </p>
          </div>
          
          <Table strollers={strollersData} />
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ANÁLISES DETALHADAS                                  -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section id="analises" class="scroll-mt-20 max-w-5xl mx-auto px-5 sm:px-8 mb-28">
      <div class="text-center mb-14 space-y-4 reveal">
        <span class="text-4xl block">🔍</span>
        <h2 class="font-display text-3xl sm:text-4xl text-text-primary">
          Análise honesta de cada um
        </h2>
        <p class="text-text-secondary text-base sm:text-lg max-w-2xl mx-auto">
          Sem papo de vendedor. A gente conta os prós, os contras e pra quem cada carrinho é ideal.
        </p>
      </div>

      <div class="space-y-12">
        {strollersData.map((stroller, i) => (
          <StrollerCard stroller={stroller} index={i} />
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- QUAL É O SEU? — Quiz visual                          -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="max-w-4xl mx-auto px-5 sm:px-8 mb-28">
      <div class="reveal">
        <div class="card overflow-hidden">
          <div class="bg-gradient-to-br from-baby-lavender/50 to-baby-pink-soft/50 px-8 sm:px-10 py-8 border-b border-brand-100/20">
            <div class="text-center space-y-3">
              <span class="text-4xl block">🤔</span>
              <h2 class="font-display text-2xl sm:text-3xl text-text-primary">Qual é o ideal pra sua família?</h2>
              <p class="text-text-secondary text-sm">Responda mentalmente e descubra:</p>
            </div>
          </div>
          
          <div class="px-8 sm:px-10 py-8 space-y-6">
            <div class="flex gap-5 items-start">
              <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-baby-sky to-baby-mint flex items-center justify-center flex-shrink-0 shadow-sm">
                <span class="text-xl">✈️</span>
              </div>
              <div class="space-y-1.5">
                <h3 class="font-bold text-text-primary text-sm">Viaja de avião ou tem porta-malas pequeno?</h3>
                <p class="text-text-light text-sm leading-relaxed">
                  Vai de <strong class="text-brand-500">Maxi-Cosi Eva³</strong> — fecha automático e cabe na cabine do avião. Sério.
                </p>
              </div>
            </div>

            <div class="border-t border-brand-50"></div>

            <div class="flex gap-5 items-start">
              <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-baby-yellow to-baby-peach flex items-center justify-center flex-shrink-0 shadow-sm">
                <span class="text-xl">🏙️</span>
              </div>
              <div class="space-y-1.5">
                <h3 class="font-bold text-text-primary text-sm">Calçadas irregulares e uso diário pesado?</h3>
                <p class="text-text-light text-sm leading-relaxed">
                  O <strong class="text-brand-500">Safety 1st Spark Plus</strong> tem suspensão real nas 4 rodas. Flutua no asfalto brasileiro.
                </p>
              </div>
            </div>

            <div class="border-t border-brand-50"></div>

            <div class="flex gap-5 items-start">
              <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-baby-pink to-baby-lavender flex items-center justify-center flex-shrink-0 shadow-sm">
                <span class="text-xl">👑</span>
              </div>
              <div class="space-y-1.5">
                <h3 class="font-bold text-text-primary text-sm">Quer o kit completo com a segurança máxima?</h3>
                <p class="text-text-light text-sm leading-relaxed">
                  <strong class="text-brand-500">Maxi-Cosi Eva³ Trio</strong> — carrinho + bebê conforto com memory foam + base. O mais seguro do Brasil.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CTA FINAL — Emocional                                -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="max-w-4xl mx-auto px-5 sm:px-8 mb-20">
      <div class="reveal">
        <div class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-brand-500 via-brand-400 to-brand-600 p-10 sm:p-14 text-center">
          
          {/* Decorações */}
          <div class="absolute top-0 left-0 w-40 h-40 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
          <div class="absolute bottom-0 right-0 w-60 h-60 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
          <div class="absolute top-6 right-8 text-5xl opacity-15 animate-float">🤍</div>
          <div class="absolute bottom-8 left-10 text-4xl opacity-10 animate-float-delayed">✨</div>
          
          <div class="relative space-y-6 max-w-xl mx-auto">
            <span class="text-5xl block">💕</span>
            <h2 class="font-display text-3xl sm:text-4xl text-white leading-snug">
              O primeiro passeio dele merece ser perfeito.
            </h2>
            <p class="text-white/80 text-base leading-relaxed">
              Preços mudam todo dia na Amazon. Se gostou de algum, <strong class="text-white">adiciona no carrinho agora</strong> — mesmo que vá decidir depois. Garante o preço e ajuda a gente a manter esse guia no ar. 💛
            </p>
            
            <div class="flex flex-col sm:flex-row gap-3 justify-center pt-2">
              {strollersData.map((s) => (
                <a 
                  href={s.affiliateLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-affiliate-btn
                  data-product-name={s.name}
                  class="bg-white text-brand-600 font-bold text-sm px-6 py-3.5 rounded-full shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
                >
                  {s.badgeIcon} {s.name.split(' ').pop()}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
