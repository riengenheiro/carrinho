---
interface Stroller {
  id: string;
  name: string;
  category: string;
  badge: string;
  badgeIcon: string;
  priceTier: string;
  priceLabel: string;
  weight: string;
  capacity: string;
  verdict: string;
  pros: string[];
  cons: string[];
  affiliateLink: string;
}

interface Props {
  stroller: Stroller;
  index: number;
}

const { stroller, index } = Astro.props;

const gradients = [
  'from-baby-pink via-baby-peach to-baby-yellow',
  'from-baby-yellow via-baby-peach to-baby-pink-soft',
  'from-baby-mint via-baby-sky to-baby-lavender',
];
const gradient = gradients[index % gradients.length];
---

<article id={stroller.id} class="reveal scroll-mt-24">
  <div class="card overflow-hidden">
    
    {/* === HEADER VISUAL === */}
    <div class={`relative bg-gradient-to-br ${gradient} px-7 sm:px-10 pt-10 pb-14`}>
      
      {/* Formas decorativas animadas */}
      <div class="absolute top-6 right-8 w-20 h-20 rounded-full bg-white/15 animate-float"></div>
      <div class="absolute bottom-8 left-12 w-14 h-14 rounded-full bg-white/10 animate-float-delayed"></div>
      <div class="absolute top-1/2 right-1/3 w-10 h-10 rounded-full bg-white/10 animate-float-slow"></div>
      
      <div class="relative flex flex-col md:flex-row items-center gap-8">
        
        {/* Espaço para foto do produto */}
        <div class="flex-shrink-0">
          <div class="relative">
            <div class="w-52 h-52 sm:w-60 sm:h-60 rounded-[2rem] bg-white/50 backdrop-blur-sm shadow-image border-2 border-white/60 flex items-center justify-center overflow-hidden group">
              {/* Substituir com <img> quando tiver as fotos */}
              <div class="text-center space-y-2 p-4">
                <span class="text-6xl block">{stroller.badgeIcon === '👑' ? '🍼' : stroller.badgeIcon === '⭐' ? '🛡️' : '✈️'}</span>
                <p class="text-text-light text-xs font-medium">Adicione a foto aqui</p>
              </div>
            </div>
            {/* Badge flutuante */}
            <div class="absolute -bottom-3 left-1/2 -translate-x-1/2">
              <span class="badge-pink text-[10px] shadow-sm">
                {stroller.badgeIcon} {stroller.badge}
              </span>
            </div>
          </div>
        </div>

        {/* Info rápida */}
        <div class="text-center md:text-left space-y-4 flex-grow">
          <div>
            <p class="text-text-light/60 text-xs font-bold uppercase tracking-widest mb-2">
              {stroller.category}
            </p>
            <h3 class="font-display text-3xl sm:text-4xl text-text-primary leading-tight">
              {stroller.name}
            </h3>
          </div>
          
          {/* Specs inline */}
          <div class="flex flex-wrap justify-center md:justify-start gap-3">
            <span class="bg-white/60 backdrop-blur-sm text-text-secondary text-xs font-medium px-4 py-2 rounded-full border border-white/40 flex items-center gap-2">
              <span>⚖️</span> {stroller.weight}
            </span>
            <span class="bg-white/60 backdrop-blur-sm text-text-secondary text-xs font-medium px-4 py-2 rounded-full border border-white/40 flex items-center gap-2">
              <span>👶</span> {stroller.capacity}
            </span>
            <span class="bg-white/60 backdrop-blur-sm text-text-secondary text-xs font-medium px-4 py-2 rounded-full border border-white/40 flex items-center gap-2">
              <span>💰</span> {stroller.priceTier} — {stroller.priceLabel}
            </span>
          </div>
        </div>
      </div>
    </div>

    {/* === CORPO === */}
    <div class="px-7 sm:px-10 py-9 space-y-8">

      {/* Veredito */}
      <div class="relative bg-baby-cream rounded-3xl p-6 sm:p-7 border border-warm-100/30">
        <div class="flex items-start gap-4">
          <span class="text-3xl flex-shrink-0 mt-1">💬</span>
          <div>
            <h4 class="font-display text-lg text-text-primary mb-2">O que eu achei de verdade</h4>
            <p class="text-text-secondary text-sm sm:text-base leading-relaxed">{stroller.verdict}</p>
          </div>
        </div>
      </div>

      {/* Prós e Contras */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        
        {/* Prós */}
        <div class="bg-gradient-to-br from-baby-mint/50 to-white rounded-3xl p-6 border border-baby-mint-deep/20">
          <div class="flex items-center gap-2.5 mb-5">
            <span class="w-8 h-8 rounded-xl bg-baby-mint flex items-center justify-center text-base shadow-sm">💚</span>
            <h4 class="font-bold text-sm text-text-primary uppercase tracking-wider">Por que eu amo</h4>
          </div>
          <ul class="space-y-3.5">
            {stroller.pros.map((pro) => (
              <li class="flex items-start gap-3 text-sm text-text-secondary leading-relaxed">
                <span class="w-5 h-5 rounded-full bg-baby-mint-deep/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-baby-mint-deep" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span>{pro}</span>
              </li>
            ))}
          </ul>
        </div>

        {/* Contras */}
        <div class="bg-gradient-to-br from-baby-pink-soft/50 to-white rounded-3xl p-6 border border-baby-pink-deep/20">
          <div class="flex items-center gap-2.5 mb-5">
            <span class="w-8 h-8 rounded-xl bg-baby-pink flex items-center justify-center text-base shadow-sm">💛</span>
            <h4 class="font-bold text-sm text-text-primary uppercase tracking-wider">Bom saber antes</h4>
          </div>
          <ul class="space-y-3.5">
            {stroller.cons.map((con) => (
              <li class="flex items-start gap-3 text-sm text-text-secondary leading-relaxed">
                <span class="w-5 h-5 rounded-full bg-baby-pink-deep/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 9v2m0 4h.01"/></svg>
                </span>
                <span>{con}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      {/* CTA */}
      <div class="relative bg-gradient-to-r from-brand-50 to-baby-pink-soft rounded-3xl p-6 sm:p-7 border border-brand-100/30">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-5">
          <div class="text-center sm:text-left space-y-1.5">
            <p class="text-text-primary font-semibold text-sm flex items-center gap-2 justify-center sm:justify-start">
              <svg class="w-4 h-4 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              Compra protegida na Amazon Brasil
            </p>
            <p class="text-text-light text-[11px]">Garantia oficial + frete facilitado com Amazon Prime</p>
          </div>
          
          <a 
            href={stroller.affiliateLink}
            target="_blank"
            rel="noopener noreferrer"
            data-affiliate-btn
            data-product-name={stroller.name}
            class="btn-cta w-full sm:w-auto text-center text-sm whitespace-nowrap"
          >
            Ver Preço de Hoje
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</article>
