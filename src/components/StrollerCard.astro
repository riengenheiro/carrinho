---
interface Stroller {
  id: string;
  name: string;
  category: string;
  badge: string;
  badgeIcon: string;
  priceTier: string;
  priceLabel: string;
  weight: string;
  capacity: string;
  verdict: string;
  pros: string[];
  cons: string[];
  affiliateLink: string;
}

interface Props {
  stroller: Stroller;
  index: number;
}

const { stroller, index } = Astro.props;
const isEven = index % 2 === 0;
---

<article id={stroller.id} class="scroll-reveal scroll-mt-24">
  <div class="bg-white rounded-3xl shadow-card overflow-hidden border border-warm-100/40 transition-all duration-500 hover:shadow-card-hover">
    
    <!-- Cabeçalho do card -->
    <div class="relative bg-gradient-to-br from-cream-100 via-white to-gold-50/30 px-7 sm:px-10 pt-8 pb-6">
      
      <!-- Número do produto -->
      <div class="absolute top-6 right-7 sm:right-10">
        <span class="text-6xl sm:text-7xl font-black text-warm-100/60 leading-none select-none">
          0{index + 1}
        </span>
      </div>
      
      <!-- Badge + Nome -->
      <div class="relative space-y-3">
        <div class="flex flex-wrap gap-2">
          <span class="badge-premium text-[10px]">
            {stroller.badgeIcon} {stroller.badge}
          </span>
          <span class="inline-flex items-center bg-white/80 text-warm-500 text-[10px] font-semibold px-3 py-1 rounded-full border border-warm-100">
            {stroller.priceTier} — {stroller.priceLabel}
          </span>
        </div>
        <h3 class="font-serif text-2xl sm:text-3xl text-warm-900 leading-tight pr-16">
          {stroller.name}
        </h3>
      </div>
    </div>

    <!-- Corpo -->
    <div class="px-7 sm:px-10 py-8 space-y-8">

      <!-- Especificações + Veredito -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        
        <!-- Specs -->
        <div class="md:col-span-5">
          <div class="bg-cream-50 rounded-2xl p-5 space-y-4 border border-cream-200/50">
            <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] text-warm-400">Especificações</h4>
            
            <div class="space-y-3">
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-xl bg-white shadow-sm border border-cream-200/50 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-warm-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
                </div>
                <div>
                  <span class="text-[10px] text-warm-400 uppercase tracking-wider font-medium block">Peso</span>
                  <span class="text-warm-800 font-semibold text-sm">{stroller.weight}</span>
                </div>
              </div>
              
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-xl bg-white shadow-sm border border-cream-200/50 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-warm-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </div>
                <div>
                  <span class="text-[10px] text-warm-400 uppercase tracking-wider font-medium block">Capacidade</span>
                  <span class="text-warm-800 font-semibold text-sm">{stroller.capacity}</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Veredito -->
        <div class="md:col-span-7 flex flex-col justify-center">
          <div class="space-y-3">
            <div class="flex items-center gap-2">
              <div class="w-1 h-6 rounded-full bg-gradient-to-b from-gold-400 to-warm-400"></div>
              <h4 class="text-sm font-bold text-warm-900 uppercase tracking-wider">O Veredito</h4>
            </div>
            <p class="text-warm-600 text-sm sm:text-base leading-relaxed">
              {stroller.verdict}
            </p>
          </div>
        </div>
      </div>

      <!-- Prós e Contras -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        
        <!-- Prós -->
        <div class="bg-sage-50/70 rounded-2xl p-6 border border-sage-100/60">
          <h4 class="flex items-center gap-2 text-sage-600 font-bold text-xs uppercase tracking-widest mb-4">
            <div class="w-6 h-6 rounded-lg bg-sage-100 flex items-center justify-center">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            </div>
            Por Que Vale a Pena
          </h4>
          <ul class="space-y-3">
            {stroller.pros.map((pro) => (
              <li class="flex items-start gap-2.5 text-sm text-warm-700 leading-relaxed">
                <span class="w-1.5 h-1.5 rounded-full bg-sage-400 flex-shrink-0 mt-2"></span>
                <span>{pro}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contras -->
        <div class="bg-blush-50/50 rounded-2xl p-6 border border-blush-100/60">
          <h4 class="flex items-center gap-2 text-blush-500 font-bold text-xs uppercase tracking-widest mb-4">
            <div class="w-6 h-6 rounded-lg bg-blush-100 flex items-center justify-center">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.5 0L4.268 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            </div>
            Saiba Antes de Comprar
          </h4>
          <ul class="space-y-3">
            {stroller.cons.map((con) => (
              <li class="flex items-start gap-2.5 text-sm text-warm-700 leading-relaxed">
                <span class="w-1.5 h-1.5 rounded-full bg-blush-300 flex-shrink-0 mt-2"></span>
                <span>{con}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row items-center justify-between gap-5 pt-6 border-t border-warm-100/50">
        <div class="text-center sm:text-left space-y-1">
          <div class="flex items-center gap-2 text-warm-500 text-xs justify-center sm:justify-start">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Compra segura na <strong>Amazon Brasil</strong>
          </div>
          <p class="text-[11px] text-warm-400">Garantia oficial e frete facilitado pelo Amazon Prime</p>
        </div>
        
        <a 
          href={stroller.affiliateLink}
          target="_blank"
          rel="noopener noreferrer"
          data-affiliate-btn
          data-product-name={stroller.name}
          class="btn-primary w-full sm:w-auto text-center text-sm"
        >
          Verificar Preço de Hoje
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>
  </div>
</article>
