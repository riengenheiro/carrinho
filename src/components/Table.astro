---
interface Stroller {
  id: string;
  name: string;
  category: string;
  badge: string;
  badgeIcon: string;
  priceTier: string;
  priceLabel: string;
  weight: string;
  capacity: string;
  verdict: string;
  image: string;
  affiliateLink: string;
}

interface Props {
  strollers: Stroller[];
}

const { strollers } = Astro.props;

const styles = [
  { gradient: 'from-baby-pink to-baby-peach', accent: 'brand', badgeClass: 'badge-pink', ring: 'ring-brand-100/40', emoji: '👑' },
  { gradient: 'from-baby-yellow to-baby-peach', accent: 'warm', badgeClass: 'badge-gold', ring: 'ring-warm-200/40', emoji: '⭐' },
  { gradient: 'from-baby-mint to-baby-sky', accent: 'emerald', badgeClass: 'badge-mint', ring: 'ring-emerald-200/40', emoji: '✈️' },
];
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  {strollers.map((stroller, i) => {
    const s = styles[i];
    return (
      <div class={`reveal reveal-delay-${i + 1} group`}>
        <div class={`card overflow-hidden flex flex-col h-full ring-1 ${s.ring}`}>
          
          {/* Área visual — gradiente + ícone animado */}
          <div class={`relative bg-gradient-to-br ${s.gradient} p-8 pb-10 text-center`}>
            {/* Formas decorativas */}
            <div class="absolute top-3 right-3 w-12 h-12 rounded-full bg-white/20 animate-float"></div>
            <div class="absolute bottom-4 left-4 w-8 h-8 rounded-full bg-white/15 animate-float-delayed"></div>
            
            {/* Imagem do produto */}
            <div class="w-32 h-32 mx-auto rounded-3xl bg-white/40 backdrop-blur-sm shadow-soft overflow-hidden mb-4 group-hover:scale-105 transition-transform duration-500 border-2 border-white/50">
              <img 
                src={stroller.image} 
                alt={stroller.name}
                class="w-full h-full object-contain p-2"
                loading="lazy"
              />
            </div>
            
            <span class={`${s.badgeClass} text-[10px]`}>
              {stroller.badgeIcon} {stroller.badge}
            </span>
          </div>

          {/* Conteúdo */}
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="font-display text-lg text-text-primary leading-snug mb-2">
              {stroller.name}
            </h3>
            
            <p class="text-text-light text-xs mb-4 leading-relaxed line-clamp-2">
              {stroller.verdict}
            </p>

            {/* Specs compactas */}
            <div class="bg-baby-cream rounded-2xl p-4 space-y-2.5 mb-5 flex-grow">
              <div class="flex items-center gap-2.5 text-sm">
                <span class="w-7 h-7 rounded-xl bg-white shadow-sm flex items-center justify-center text-xs flex-shrink-0">⚖️</span>
                <div>
                  <span class="text-[10px] text-text-muted uppercase tracking-wider font-medium block">Peso</span>
                  <span class="text-text-primary font-semibold text-xs">{stroller.weight}</span>
                </div>
              </div>
              <div class="flex items-center gap-2.5 text-sm">
                <span class="w-7 h-7 rounded-xl bg-white shadow-sm flex items-center justify-center text-xs flex-shrink-0">👶</span>
                <div>
                  <span class="text-[10px] text-text-muted uppercase tracking-wider font-medium block">Capacidade</span>
                  <span class="text-text-primary font-semibold text-xs">{stroller.capacity}</span>
                </div>
              </div>
            </div>

            {/* Preço */}
            <div class="flex items-center justify-between mb-5">
              <div>
                <span class="text-2xl font-black text-text-primary tracking-wider">{stroller.priceTier}</span>
                <span class="text-[10px] text-text-muted block">{stroller.priceLabel}</span>
              </div>
            </div>

            {/* CTA */}
            <a 
              href={stroller.affiliateLink}
              target="_blank"
              rel="noopener noreferrer"
              data-affiliate-btn
              data-product-name={stroller.name}
              class="btn-cta w-full text-center text-sm py-3.5"
            >
              Ver na Amazon
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </div>
        </div>
      </div>
    );
  })}
</div>
