---
interface Stroller {
  id: string;
  name: string;
  category: string;
  badge: string;
  badgeIcon: string;
  priceTier: string;
  priceLabel: string;
  weight: string;
  capacity: string;
  verdict: string;
  affiliateLink: string;
}

interface Props {
  strollers: Stroller[];
}

const { strollers } = Astro.props;

const cardStyles = [
  { accent: 'from-gold-400 to-amber-500', bg: 'bg-gradient-to-br from-gold-50/80 to-cream-100/80', ring: 'ring-gold-200/60' },
  { accent: 'from-warm-400 to-warm-500', bg: 'bg-gradient-to-br from-warm-50/80 to-cream-100/80', ring: 'ring-warm-200/60' },
  { accent: 'from-sage-400 to-sage-500', bg: 'bg-gradient-to-br from-sage-50/80 to-cream-100/80', ring: 'ring-sage-200/60' },
];
---

<div class="scroll-reveal">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6">
    {strollers.map((stroller, i) => {
      const style = cardStyles[i % cardStyles.length];
      return (
        <div class={`relative ${style.bg} rounded-3xl p-6 sm:p-7 ring-1 ${style.ring} shadow-soft transition-all duration-500 hover:shadow-card-hover hover:-translate-y-1 flex flex-col`}>
          
          {/* Linha de acento superior */}
          <div class={`absolute top-0 left-6 right-6 h-1 rounded-b-full bg-gradient-to-r ${style.accent}`}></div>
          
          {/* Badge */}
          <div class="mb-4 mt-1">
            <span class="badge-premium text-[10px]">
              {stroller.badgeIcon} {stroller.badge}
            </span>
          </div>

          {/* Nome */}
          <h3 class="font-serif text-lg text-warm-900 leading-snug mb-3">
            {stroller.name}
          </h3>

          {/* Preço tier */}
          <div class="flex items-baseline gap-2 mb-4">
            <span class="text-2xl font-black text-warm-700 tracking-wider">{stroller.priceTier}</span>
            <span class="text-[11px] text-warm-400 font-medium">{stroller.priceLabel}</span>
          </div>

          {/* Specs rápidas */}
          <div class="bg-white/60 rounded-2xl p-4 space-y-3 text-sm mb-5 flex-grow">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-xl bg-white shadow-sm flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-warm-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
              </div>
              <div>
                <span class="text-[10px] text-warm-400 uppercase tracking-wider font-medium block">Peso</span>
                <span class="text-warm-800 font-semibold text-xs">{stroller.weight}</span>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-xl bg-white shadow-sm flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-warm-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
              <div>
                <span class="text-[10px] text-warm-400 uppercase tracking-wider font-medium block">Capacidade</span>
                <span class="text-warm-800 font-semibold text-xs">{stroller.capacity}</span>
              </div>
            </div>
          </div>

          {/* CTA */}
          <a 
            href={stroller.affiliateLink}
            target="_blank"
            rel="noopener noreferrer"
            data-affiliate-btn
            data-product-name={stroller.name}
            class="btn-primary w-full text-center text-sm py-3.5"
          >
            Verificar Preço na Amazon
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      );
    })}
  </div>
</div>
